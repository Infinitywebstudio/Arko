# Supabase — copy to .env.local and fill from Supabase Dashboard > Settings > API
# NEXT_PUBLIC_* are exposed to the browser; SUPABASE_SERVICE_ROLE_KEY is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public canonical URL of the site. Used in auth emails (verify, reset).
# Local dev: http://localhost:3000. Production: the canonical site URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — copy from Stripe Dashboard > Developers > API keys (test mode in dev).
# STRIPE_SECRET_KEY is server-only; NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is exposed
# to the browser by Next. STRIPE_WEBHOOK_SECRET comes from `stripe listen` in
# local dev or from Dashboard > Developers > Webhooks in production.
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Resend — transactional emails (booking notifications). Get a key from
# resend.com > API Keys. RESEND_FROM_EMAIL must be a verified sender on a domain
# you own; while developing you can use Resend's onboarding sender.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=ARKO <onboarding@resend.dev>

# Cron secret — guards /api/cron/sweep, which is the auto-refund + auto-close
# job. Generate any random string (e.g. `openssl rand -hex 32`). Vercel reads
# this same env var on its Cron platform to authenticate cron invocations.
CRON_SECRET=replace_with_random_hex

# DEMO MODE — set to `true` to walk through the booking flow without a Stripe
# account or a Resend key. Payments are auto-confirmed in-app, refunds skip
# the Stripe API, emails are console-logged instead of sent. Useful for demos
# before the real Stripe/Resend setup is provisioned. MUST be unset (or false)
# in production.
DEMO_MODE=false
